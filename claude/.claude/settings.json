{
  "env": {
    "DISABLE_ZOXIDE": "1",
    "_ZO_DOCTOR": "0"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(clang-format*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(git blame*)",
      "Bash(git branch*)",
      "Bash(git describe*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git remote*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git status*)",
      "Bash(git tag*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(run-clang-tidy*)",
      "Bash(tree:*)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash /home/xiaomin/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": false
}
