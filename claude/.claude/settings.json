{
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git blame*)",
      "Bash(git stash list*)",
      "Bash(git tag*)",
      "Bash(git remote*)",
      "Bash(git describe*)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); model=$(echo \"$input\" | jq -r '.model.display_name // empty'); ctx=${used:+\" | ctx: ${used}%\"}; mdl=${model:+\" | ${model}\"}; echo \"[$(whoami)@$(basename \"$(pwd)\")]${ctx}${mdl}\""
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
